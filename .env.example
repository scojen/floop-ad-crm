# Base URL of ad-manager-api (the Meta Ads microservice)
VITE_CRM_BASE_URL=http://localhost:3001

# Shared service bearer token — must equal ad-manager-api's SERVICE_AUTH_TOKEN.
# Leave empty when the backend runs with auth disabled (local dev only).
VITE_CRM_TOKEN=

# The single-tenant client UUID (from POST /clients / scripts/seed-client.ts)
VITE_CRM_CLIENT_ID=
